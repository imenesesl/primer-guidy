{
  "rules": {
    ".read": false,
    ".write": false,

    "studentCredentials": {
      "$identificationNumber": {
        ".read": false,
        ".write": false
      }
    },

    "codes": {
      "$code": {
        ".read": "auth != null",
        ".write": false
      }
    },

    "userCodes": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    }
  }
}

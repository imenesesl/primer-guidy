{
  "extends": ["stylelint-config-standard-scss"],
  "plugins": ["stylelint-declaration-strict-value"],
  "rules": {
    "declaration-no-important": true,
    "property-disallowed-list": [
      "margin",
      "margin-top",
      "margin-right",
      "margin-bottom",
      "margin-left"
    ],
    "selector-class-pattern": "^[a-z][a-zA-Z0-9]+$",
    "no-descending-specificity": true,
    "scale-unlimited/declaration-strict-value": [
      [
        "color",
        "background-color",
        "border-color",
        "fill",
        "stroke",
        "font-size",
        "font-weight",
        "line-height",
        "border-radius",
        "box-shadow",
        "z-index"
      ],
      {
        "ignoreValues": ["inherit", "initial", "unset", "currentColor", "transparent", "none", "0"],
        "disableFix": true,
        "message": "Use a Tailwind token (var(--*) or @apply) instead of a hardcoded value for '${property}'"
      }
    ],
    "scss/operator-no-unspaced": null,
    "scss/at-rule-no-unknown": [true, {
      "ignoreAtRules": ["apply", "reference", "theme", "screen", "responsive", "variants", "tailwind"]
    }],
    "at-rule-no-unknown": null
  }
}

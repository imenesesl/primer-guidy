{
  "hosting": {
    "target": "app",
    "public": "deploy",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/core/**", "destination": "/core/index.html" },
      { "source": "/login/**", "destination": "/login/index.html" },
      { "source": "/flow/**", "destination": "/flow/index.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "ui": { "enabled": true, "port": 4000 }
  }
}

{
  "name": "primer-guidy",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "npx tsx scripts/dev-proxy.ts",
    "dev:core": "pnpm --filter @primer-guidy/core-web dev",
    "dev:login": "pnpm --filter @primer-guidy/login-web dev",
    "dev:flow": "pnpm --filter @primer-guidy/flow-web dev",
    "build": "pnpm -r build",
    "generate:landing": "npx tsx .github/pages/generate.ts",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r lint",
    "lint:css": "pnpm -r lint:css",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "test:e2e": "pnpm -r --workspace-concurrency=1 test:e2e",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.module.scss": [
      "stylelint --fix"
    ],
    "*.{ts,tsx,scss,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "firebase-tools": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "stylelint": "^17.8.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-scss": "^7.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}

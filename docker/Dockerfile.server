ARG APP_NAME
ARG APP_PORT=3010

FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /app

FROM base AS deps
ARG APP_NAME
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY libs/llm-services/package.json ./libs/llm-services/
COPY libs/nest-shared/package.json ./libs/nest-shared/
COPY apps/${APP_NAME}/package.json ./apps/${APP_NAME}/
RUN pnpm install --frozen-lockfile --filter @primer-guidy/${APP_NAME}...

FROM base AS build
ARG APP_NAME
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/libs/llm-services/node_modules ./libs/llm-services/node_modules
COPY --from=deps /app/libs/nest-shared/node_modules ./libs/nest-shared/node_modules
COPY --from=deps /app/apps/${APP_NAME}/node_modules ./apps/${APP_NAME}/node_modules
COPY libs/llm-services/ ./libs/llm-services/
COPY libs/nest-shared/ ./libs/nest-shared/
COPY apps/${APP_NAME}/ ./apps/${APP_NAME}/
COPY tsconfig.base.json tsconfig.nest.json ./
WORKDIR /app/apps/${APP_NAME}
RUN npx nest build

FROM node:22-alpine AS production
ARG APP_NAME
ARG APP_PORT
WORKDIR /app
COPY --from=build /app/apps/${APP_NAME}/dist ./dist
COPY --from=deps /app/apps/${APP_NAME}/node_modules ./node_modules
ENV NODE_ENV=production
EXPOSE ${APP_PORT}
CMD ["node", "dist/main.js"]
